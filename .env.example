PORT=8080
APP_ENV=development
APP_ORG_ID=ORG-dev-001
DATABASE_URL=postgres://postgres:yourpassword@localhost:5432/payroll_db?sslmode=disable
REDIS_URL=localhost:6379
MIGRATIONS_PATH=file://internal/db/migrations

# API auth key for machine-to-machine calls (webhooks, internal tooling)
APP_API_KEY=change-me-to-a-strong-random-secret

# JWT signing secret — generate with: openssl rand -base64 64
# Rotate this to invalidate all active sessions instantly
JWT_SECRET=change-me-to-a-long-random-secret

# 32-byte base64 KEK — generate with: openssl rand -base64 32
# In production use AWS KMS; never commit a real key here
ENCRYPTION_KEK=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# Monnify credentials
MONNIFY_API_KEY=your_api_key
MONNIFY_SECRET_KEY=your_secret_key
MONNIFY_BASE_URL=https://sandbox.monnify.com
MONNIFY_SOURCE_WALLET=your_wallet_number

# BVN verification (Dojah) — leave blank to use mock mode
DOJAH_API_KEY=
DOJAH_APP_ID=

# SOC 2 evidence output directory
SOC2_EVIDENCE_DIR=./evidence

# Observability
APP_VERSION=0.1.0
DATA_REGIONS=ng
GRAFANA_PASSWORD=changeme
# SENTRY_DSN=https://your-sentry-dsn (add when you create a Sentry project)

APP_MODE=api

# WARNING: MOCK_MODE=true is blocked when APP_ENV=production
MOCK_MODE=true

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=payroll_db
